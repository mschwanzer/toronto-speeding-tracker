<script src="https://cdn.jsdelivr.net/npm/echarts@5.5.1/dist/echarts.min.js"></script>
<script>window.WHENSPEED = {{WHENSPEED_JSON}};</script>
<script>
(function () {
  const D = window.WHENSPEED;
  document.getElementById("generatedAt").textContent = D.generated_at;

  const pct = v => (v == null) ? "—" : (Math.round(v * 1000) / 10).toFixed(1) + "%";
  const fmtN = v => (v == null) ? "—" : Number(v).toLocaleString();

  // Headline shares — school vs outside (tier 10)
  const SCHOOL_HOURS_WK = 35;  // Mon-Fri 8-3
  const TOTAL_HOURS_WK = 168;
  const outsideShare = D.city.share_outside_school_ge10;
  const schoolShare = 1 - outsideShare;
  document.getElementById("schoolPct").textContent = (schoolShare * 100).toFixed(0) + "%";
  document.getElementById("outsidePct").textContent = (outsideShare * 100).toFixed(0) + "%";
  // Per-hour multipliers relative to the average
  const schoolMult = (schoolShare / (SCHOOL_HOURS_WK / TOTAL_HOURS_WK));
  const outsideMult = (outsideShare / ((TOTAL_HOURS_WK - SCHOOL_HOURS_WK) / TOTAL_HOURS_WK));
  const ratio = outsideMult / schoolMult;  // outside-vs-school per-hour
  document.getElementById("schoolMult").textContent = schoolMult.toFixed(2) + "×";
  document.getElementById("outsideMult").textContent = (ratio).toFixed(2) + "×";
  document.getElementById("hl30").firstChild.nodeValue = (D.city.share_outside_school_ge30 * 100).toFixed(1);

  // Post-ban tier totals (from the existing yoy_city, already on the dashboard)
  const t10 = D.post_ban_tiers["10"];
  const t30 = D.post_ban_tiers["30"];
  const fmtDelta = (t) => {
    if (!t || t.delta == null) return "—";
    const pctTxt = t.pct == null ? "" : ` (${t.pct > 0 ? "+" : ""}${t.pct.toFixed(1)}%)`;
    return `${t.delta > 0 ? "+" : ""}${Number(t.delta).toLocaleString()}${pctTxt}`;
  };
  document.getElementById("postBan10").textContent = fmtDelta(t10);
  document.getElementById("postBan30").textContent = fmtDelta(t30);

  // Hour-of-day chart: combine weekday + weekend per hour for the three tiers.
  const hours = Array.from({length: 24}, (_, i) => i);
  const combine = (wk, we) => hours.map(h => (wk[h] || 0) + (we[h] || 0));
  const series10 = combine(D.city.wk_hour_ge10, D.city.we_hour_ge10);
  const series20 = combine(D.city.wk_hour_ge20, D.city.we_hour_ge20);
  const series30 = combine(D.city.wk_hour_ge30, D.city.we_hour_ge30);
  const hourChart = echarts.init(document.getElementById("hourChart"), null, { renderer: "canvas" });
  hourChart.setOption({
    grid: { left: 60, right: 20, top: 36, bottom: 50 },
    legend: { top: 0, textStyle: { fontSize: 13 } },
    tooltip: { trigger: "axis", valueFormatter: v => v == null ? "—" : Number(v).toLocaleString() + " veh" },
    xAxis: {
      type: "category",
      data: hours.map(h => (h % 6 === 0) ? (h.toString().padStart(2, "0") + ":00") : ""),
      axisLabel: { interval: 0, fontSize: 11 },
      name: "Hour of day (24h)", nameLocation: "middle", nameGap: 30,
    },
    yAxis: { type: "value", scale: false, axisLabel: { formatter: v => v >= 1e6 ? (v/1e6).toFixed(1) + "M" : v >= 1e3 ? (v/1e3).toFixed(0) + "k" : v } },
    series: [
      { name: "10+ over limit", type: "line", smooth: true, symbol: "none", data: series10, lineStyle: { width: 2, color: "#16a34a" }, areaStyle: { color: "rgba(22,163,74,0.10)" } },
      { name: "20+ over limit", type: "line", smooth: true, symbol: "none", data: series20, lineStyle: { width: 2, color: "#f97316" }, areaStyle: { color: "rgba(249,115,22,0.10)" } },
      { name: "30+ over limit", type: "line", smooth: true, symbol: "none", data: series30, lineStyle: { width: 2.5, color: "#dc2626" }, areaStyle: { color: "rgba(220,38,38,0.12)" },
        markArea: { silent: true, itemStyle: { color: "rgba(15,23,42,0.05)" }, data: [[{ xAxis: 8 }, { xAxis: 15 }]] },
      },
    ],
  });
  window.addEventListener("resize", () => hourChart.resize());

  // DOW chart: weekdays + weekend, three tiers as grouped bars.
  const dowLabels = ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"];
  const dowChart = echarts.init(document.getElementById("dowChart"), null, { renderer: "canvas" });
  dowChart.setOption({
    grid: { left: 60, right: 20, top: 36, bottom: 30 },
    legend: { top: 0, textStyle: { fontSize: 13 } },
    tooltip: { trigger: "axis", axisPointer: { type: "shadow" }, valueFormatter: v => v == null ? "—" : Number(v).toLocaleString() + " veh" },
    xAxis: { type: "category", data: dowLabels },
    yAxis: { type: "value", axisLabel: { formatter: v => v >= 1e6 ? (v/1e6).toFixed(1) + "M" : v >= 1e3 ? (v/1e3).toFixed(0) + "k" : v } },
    series: [
      { name: "10+ over", type: "bar", data: D.city.dow_ge10, itemStyle: { color: "#16a34a", borderRadius: [2,2,0,0] } },
      { name: "20+ over", type: "bar", data: D.city.dow_ge20, itemStyle: { color: "#f97316", borderRadius: [2,2,0,0] } },
      { name: "30+ over", type: "bar", data: D.city.dow_ge30, itemStyle: { color: "#dc2626", borderRadius: [2,2,0,0] } },
    ],
  });
  window.addEventListener("resize", () => dowChart.resize());

  // Sample signs
  const samples = D.samples || {};
  const samplesGrid = document.getElementById("sampleGrid");
  const caseDefs = [
    { key: "overnight", label: "Worst pattern: overnight",
      headline: s => `${(s.share_overnight_ge10 * 100).toFixed(0)}% of all 10+ over the limit driving here happens between 10 pm and 6 am.`,
      meta: s => `Ward ${s.ward} · Limit ${s.limit} km/h · Worst hour: ${String(s.worst_hour).padStart(2, "0")}:00`,
      stats: s => [
        ["overnight 10pm–6am", (s.share_overnight_ge10 * 100).toFixed(0) + "%"],
        ["total 10+ over (2023)", Number(s.total_ge10).toLocaleString()],
        ["total 30+ over (2023)", Number(s.total_ge30 || 0).toLocaleString()],
      ],
    },
    { key: "weekend", label: "Worst pattern: weekends",
      headline: s => `${(s.share_weekend_ge10 * 100).toFixed(0)}% of all 10+ over the limit driving at this sign happens on a Saturday or Sunday.`,
      meta: s => `Ward ${s.ward} · Limit ${s.limit} km/h · Worst hour: ${String(s.worst_hour).padStart(2, "0")}:00`,
      stats: s => [
        ["weekend share", (s.share_weekend_ge10 * 100).toFixed(0) + "%"],
        ["total 10+ over (2023)", Number(s.total_ge10).toLocaleString()],
        ["total 20+ over (2023)", Number(s.total_ge20 || 0).toLocaleString()],
      ],
    },
    { key: "outside_school", label: "Worst pattern: outside school hours",
      headline: s => `${(s.share_outside_school_ge10 * 100).toFixed(0)}% of all 10+ over driving at this sign happens outside Mon–Fri 8 am to 3 pm.`,
      meta: s => `Ward ${s.ward} · Limit ${s.limit} km/h · Worst hour: ${String(s.worst_hour).padStart(2, "0")}:00`,
      stats: s => [
        ["outside school hours", (s.share_outside_school_ge10 * 100).toFixed(0) + "%"],
        ["total 10+ over (2023)", Number(s.total_ge10).toLocaleString()],
        ["worst hour", String(s.worst_hour).padStart(2, "0") + ":00"],
      ],
    },
  ];
  caseDefs.forEach(def => {
    const s = samples[def.key];
    if (!s) return;
    const div = document.createElement("div");
    div.className = "sample";
    const statsHtml = def.stats(s).map(([lbl, val]) => `<div><div class="big">${val}</div><div class="lbl">${lbl}</div></div>`).join("");
    div.innerHTML = `
      <div class="case">${def.label}</div>
      <h3>${s.name} · Sign ${s.sign_id}</h3>
      <div class="meta">${def.meta(s)}</div>
      <p style="margin: 0 0 8px;">${def.headline(s)}</p>
      <div class="nums">${statsHtml}</div>
      <div class="chart" id="sample-${def.key}"></div>
    `;
    samplesGrid.appendChild(div);
    const c = echarts.init(div.querySelector(".chart"), null, { renderer: "canvas" });
    const hourly = hours.map(h => (s.wk_hour_ge10[h] || 0) + (s.we_hour_ge10[h] || 0));
    c.setOption({
      grid: { left: 36, right: 8, top: 6, bottom: 22 },
      tooltip: { trigger: "axis", valueFormatter: v => v == null ? "—" : Number(v).toLocaleString() + " veh" },
      xAxis: { type: "category", data: hours.map(h => (h % 6 === 0) ? (h.toString().padStart(2,"0")) : ""), axisLabel: { interval: 0, fontSize: 9 } },
      yAxis: { type: "value", axisLabel: { fontSize: 9, formatter: v => v >= 1e3 ? (v/1e3).toFixed(0) + "k" : v } },
      series: [{ type: "bar", data: hourly, itemStyle: { color: "#dc2626", borderRadius: [1,1,0,0] }, barCategoryGap: "20%",
        markArea: { silent: true, itemStyle: { color: "rgba(15,23,42,0.06)" }, data: [[{ xAxis: 8 }, { xAxis: 15 }]] },
      }],
    });
    window.addEventListener("resize", () => c.resize());
  });
})();
</script>
</body>
</html>
