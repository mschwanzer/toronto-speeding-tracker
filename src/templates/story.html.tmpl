<script>window.STORY = {{STORY_JSON}};</script>
<script src="https://unpkg.com/echarts@5.5.1/dist/echarts.min.js"></script>
<script>
(function () {
  const S = window.STORY;
  document.getElementById("generatedAt").textContent = S.generated_at;

  const fmt = {
    pp: v => v == null ? "—" : (v >= 0 ? "+" : "") + v.toFixed(2) + " pp",
    pct: v => v == null ? "—" : v.toFixed(2) + "%",
    int: v => v == null ? "—" : Math.round(v).toLocaleString(),
  };

  // City trend with ASE-ban marker
  echarts.init(document.getElementById("cityTrend"), null, { renderer: "canvas" }).setOption({
    grid: { left: 50, right: 24, top: 30, bottom: 56 },
    tooltip: { trigger: "axis", valueFormatter: v => v == null ? "—" : v.toFixed(2) + "%" },
    xAxis: { type: "time", boundaryGap: false },
    yAxis: { type: "value", axisLabel: { formatter: "{value}%" }, splitLine: { lineStyle: { color: "#eef0f4" } } },
    series: [{
      type: "line", smooth: true, symbol: "none", lineStyle: { width: 2, color: "#c0392b" },
      areaStyle: { color: "rgba(192,57,43,.10)" }, data: S.city_series,
      markLine: { symbol: "none", silent: true, lineStyle: { color: "#0f172a", type: "dashed", width: 1.2 },
                  label: { formatter: "ASE banned\nNov 2025", position: "insideStartTop", color: "#0f172a", fontSize: 11 },
                  data: [{ xAxis: "2025-11-01" }] },
      markArea: { silent: true, itemStyle: { color: "rgba(15,23,42,.05)" }, data: [
        [{ xAxis: "2025-07-01" }, { xAxis: "2025-10-31" }],
        [{ xAxis: "2025-12-01" }, { xAxis: "2026-03-31" }],
      ] },
    }],
    dataZoom: [{ type: "inside", start: 50, end: 100 }, { type: "slider", height: 16, bottom: 14, start: 50, end: 100 }],
  });

  // Tier bars (this year vs last year)
  const tiers = S.tiers;
  echarts.init(document.getElementById("tierBars"), null, { renderer: "canvas" }).setOption({
    grid: { left: 70, right: 24, top: 40, bottom: 30 },
    legend: { top: 0 },
    tooltip: { trigger: "axis", valueFormatter: v => v == null ? "—" : Number(v).toLocaleString() + " vehicles" },
    xAxis: { type: "category", data: tiers.map(t => `${t.tier}+ km/h over`) },
    yAxis: { type: "value", axisLabel: { formatter: v => v >= 1e6 ? (v/1e6).toFixed(1) + "M" : v >= 1000 ? (v/1000).toFixed(0) + "k" : v } },
    series: [
      { name: "Last year (Jan–Apr 2025)", type: "bar", data: tiers.map(t => t.last), itemStyle: { color: "#94a3b8", borderRadius: [2,2,0,0] } },
      { name: "This year (Jan–Apr 2026)", type: "bar", data: tiers.map(t => t.this), itemStyle: { color: "#c0392b", borderRadius: [2,2,0,0] },
        label: { show: true, position: "top", fontSize: 11, color: "#0f172a", formatter: p => "+" + tiers[p.dataIndex].pct.toFixed(1) + "%" } },
    ],
  });

  // Ward ranking horizontal
  const wards = S.wards.slice().sort((a,b) => a.did - b.did); // ascending so largest sits at top
  echarts.init(document.getElementById("wardBars"), null, { renderer: "canvas" }).setOption({
    grid: { left: 240, right: 90, top: 16, bottom: 30 },
    tooltip: { trigger: "axis", axisPointer: { type: "shadow" },
               formatter: p => { const w = wards[p[0].dataIndex];
                                  return `<b>Ward ${w.ward} · ${w.name}</b><br>${w.n_signs} signs<br>DiD-adjusted: <b>${fmt.pp(w.did)}</b>`; } },
    xAxis: { type: "value", axisLabel: { formatter: v => (v >= 0 ? "+" : "") + v.toFixed(1) } },
    yAxis: { type: "category", data: wards.map(w => `Ward ${w.ward} · ${w.name}`), axisLabel: { fontSize: 12 } },
    series: [{ type: "bar",
               data: wards.map(w => ({ value: Number(w.did.toFixed(2)),
                                        itemStyle: { color: w.did > 0 ? "#c0392b" : "#2e7d4f", borderRadius: [0,2,2,0] } })),
               label: { show: true, position: "right", fontSize: 11, formatter: p => fmt.pp(p.value) } }],
  });

  // Spatial DiD
  const sp = S.spatial;
  echarts.init(document.getElementById("spatialBars"), null, { renderer: "canvas" }).setOption({
    grid: { left: 60, right: 24, top: 40, bottom: 30 },
    legend: { top: 0 },
    tooltip: { trigger: "axis", valueFormatter: v => v == null ? "—" : fmt.pp(v) },
    xAxis: { type: "category", data: sp.map(b => b.label + `\n(${b.n_signs} signs)`), axisLabel: { lineHeight: 16, fontSize: 12 } },
    yAxis: { type: "value", axisLabel: { formatter: v => (v >= 0 ? "+" : "") + v.toFixed(1) + " pp" } },
    series: [
      { name: "Raw 2025 change", type: "bar", data: sp.map(b => Number(b.delta_2025.toFixed(2))),
        itemStyle: { color: "#94a3b8", borderRadius: [2,2,0,0] },
        label: { show: true, position: "top", fontSize: 11, formatter: p => fmt.pp(p.value) } },
      { name: "DiD-adjusted (controls for 2024 seasonality)", type: "bar", data: sp.map(b => Number(b.did.toFixed(2))),
        itemStyle: { color: "#c0392b", borderRadius: [2,2,0,0] },
        label: { show: true, position: "top", fontSize: 11, color: "#c0392b", formatter: p => fmt.pp(p.value) } },
    ],
  });

  // RTO section
  if (S.rto && S.rto.areas) {
    document.getElementById("rtoSection").style.display = "";
    const order = ["downtown", "midtown", "outer"];
    const psign = v => v == null ? "—" : (v >= 0 ? "+" : "") + v.toFixed(1) + " pp";
    const csign = v => v == null ? "—" : (v >= 0 ? "+" : "") + v.toFixed(1) + "%";
    const rowEl = document.getElementById("rtoRow");
    rowEl.innerHTML = order.filter(k => S.rto.areas[k]).map(k => {
      const a = S.rto.areas[k];
      const cls = a.did_pp > 0 ? "pos" : "neg";
      const tileCls = k === "downtown" ? "downtown" : "";
      return `<div class="rto-cell ${tileCls}">
        <div class="area">${a.label}</div>
        <div class="desc">${a.wards_desc}</div>
        <div class="num ${cls}">${psign(a.did_pp)}</div>
        <div class="sub">RTO yr: <b>${csign(a.rto_pct)}</b><br>Prior baseline: ${csign(a.baseline_pct)}</div>
      </div>`;
    }).join("");
    const dt = S.rto.areas.downtown, out_ = S.rto.areas.outer;
    if (dt && out_) {
      document.getElementById("rtoPull").textContent =
        `Downtown traffic on monitored streets grew ${dt.rto_pct.toFixed(0)}% across the OPS RTO window. The same streets fell ${Math.abs(dt.baseline_pct).toFixed(0)}% the year before. Outer-416 wards moved ${out_.rto_pct.toFixed(0)}% — far below their own ${out_.baseline_pct.toFixed(0)}% baseline. The split is exactly the geographic signature of an in-office mandate.`;
    }
  }

  // Distribution shift
  const d = S.distribution;
  echarts.init(document.getElementById("distShift"), null, { renderer: "canvas" }).setOption({
    grid: { left: 50, right: 20, top: 36, bottom: 46 },
    legend: { top: 0, textStyle: { fontSize: 12 } },
    tooltip: { trigger: "axis", valueFormatter: v => v == null ? "—" : Number(v).toFixed(2) + "%" },
    xAxis: { type: "category", data: d.labels, name: "Measured speed (km/h)", nameLocation: "middle", nameGap: 28, axisLabel: { interval: 1, fontSize: 10 } },
    yAxis: { type: "value", name: "% of all measurements", nameLocation: "middle", nameGap: 38, axisLabel: { formatter: "{value}%" } },
    series: [
      { name: "2024 pre",  type: "line", smooth: true, symbol: "none", lineStyle: { color: "#94a3b8", width: 1.5, type: "dotted" }, data: d.pre_2024_pct },
      { name: "2024 post", type: "line", smooth: true, symbol: "none", lineStyle: { color: "#475569", width: 1.5, type: "dotted" }, data: d.post_2024_pct },
      { name: "2025 pre",  type: "line", smooth: true, symbol: "none", lineStyle: { color: "#1a56db", width: 2 }, areaStyle: { color: "rgba(26,86,219,.06)" }, data: d.pre_2025_pct },
      { name: "2025 post", type: "line", smooth: true, symbol: "none", lineStyle: { color: "#c0392b", width: 2.5 }, areaStyle: { color: "rgba(192,57,43,.12)" }, data: d.post_2025_pct },
    ],
  });
})();
</script>

</body>
</html>
