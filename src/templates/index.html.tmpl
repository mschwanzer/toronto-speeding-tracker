  th.sorted.asc::after { content: " \25B4"; }
  tr.signrow { cursor: pointer; }
  tr.signrow:hover { background: #f3f5f9; }
  .ase-flag { display: inline-block; font-size: 13px; line-height: 1; margin-right: 4px; vertical-align: -1px; cursor: help; filter: grayscale(0.1); }
  .num { font-variant-numeric: tabular-nums; text-align: right; }

  .panel { display: none; }
  .panel.open { display: block; }

  footer { padding: 40px 32px; color: var(--ink-soft); font-size: 13px; border-top: 1px solid var(--line); background: #fff; margin-top: 40px; }
  footer .wrap { padding: 0; }
  footer h3 { color: var(--ink); margin-top: 1em; }
  footer ul { padding-left: 18px; }
  footer code { background: #eef0f4; padding: 1px 5px; border-radius: 3px; font-size: 12px; }

  @media (max-width: 900px) {
    .kpis { grid-template-columns: repeat(2, 1fr); }
