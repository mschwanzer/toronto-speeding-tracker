<script>window.WYS_SUMMARY = {{SUMMARY_JSON}};</script>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
        integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
<script src="https://unpkg.com/leaflet.markercluster@1.5.3/dist/leaflet.markercluster.js"></script>
<script src="https://unpkg.com/echarts@5.5.1/dist/echarts.min.js"></script>
<script>
(function () {
  const S = window.WYS_SUMMARY;
  let FULL = null; // lazy loaded data.json

  // ---------- formatters ----------
  const fmt = {
    pct: (v, dp=1) => v == null ? "—" : v.toFixed(dp) + "%",
    pp:  (v, dp=2) => v == null ? "—" : (v >= 0 ? "+" : "") + v.toFixed(dp) + " pp",
    int: v => v == null ? "—" : Math.round(v).toLocaleString(),
    intPct: (v, dp=1) => v == null ? "—" : (v >= 0 ? "+" : "") + v.toFixed(dp) + "%",
  };
  const colorFor = (v, lo=2, hi=18) => {
    if (v == null) return "#9aa0a6";
    const t = Math.max(0, Math.min(1, (v - lo) / (hi - lo)));
    const r = Math.round(46 + (192 - 46) * t);
    const g = Math.round(125 + (57 - 125) * t);
    const b = Math.round(79 + (43 - 79) * t);
    return `rgb(${r},${g},${b})`;
  };

  // ---------- KPI tiles ----------
  function renderKPIs() {
    const k = S.headline;
    const did = k.did;
    const sign = did == null ? "neutral" : (did > 0 ? "pos" : "neg");
    const arrow = did == null ? "" : (did > 0 ? "▲" : "▼");
    const html = `
      <div class="kpi"><div class="label">Pre-ban (Jul–Oct 2025)</div>
        <div class="value">${fmt.pct(k.pre_2025)}</div>
        <div class="sub">avg % &gt;10 over limit</div></div>
      <div class="kpi"><div class="label">Post-ban (Dec 2025–Mar 2026)</div>
        <div class="value">${fmt.pct(k.post_2025)}</div>
        <div class="sub">avg % &gt;10 over limit</div></div>
      <div class="kpi"><div class="label">Raw change</div>
        <div class="value ${k.delta_2025 == null ? 'neutral' : (k.delta_2025 > 0 ? 'pos' : 'neg')}">${fmt.pp(k.delta_2025)}</div>
        <div class="sub">post − pre, 2025</div></div>
      <div class="kpi headline"><div class="label">DiD-adjusted change</div>
        <div class="value ${sign}">${arrow} ${fmt.pp(did)}</div>
        <div class="sub">post − pre, minus same delta in 2024</div></div>`;
    document.getElementById("kpis").innerHTML = html;
    document.getElementById("refreshedAt").textContent = S.generated_at;
  }

  // ---------- spatial DiD (distance to nearest ASE) ----------
  function renderSpatial() {
    if (!S.spatial_did || !S.spatial_did.length) return;
    const data = S.spatial_did;
    // Only show bins with at least a few signs; tiny bins are too noisy
    const visible = data.filter(d => d.n_signs >= 5 && d.delta_2025 != null);
    if (!visible.length) return;
    document.getElementById("spatialCard").style.display = "";
    const chart = echarts.init(document.getElementById("spatialChart"), null, { renderer: "canvas" });
    chart.setOption({
      grid: { left: 70, right: 24, top: 40, bottom: 50 },
      legend: { top: 0, textStyle: { fontSize: 12 } },
      tooltip: {
        trigger: "axis", axisPointer: { type: "shadow" },
        formatter: p => {
          const i = p[0].dataIndex; const it = visible[i];
          return `<b>${it.label}</b><br>${it.n_signs} signs in this bin<br>` +
                 `2025 pre: ${fmt.pct(it.pre_2025)} → post: ${fmt.pct(it.post_2025)} (${fmt.pp(it.delta_2025)})<br>` +
                 `2024 same windows: ${fmt.pp(it.delta_2024)}<br>` +
                 `<b>DiD-adjusted: ${fmt.pp(it.did)}</b>`;
        },
      },
      xAxis: { type: "category", data: visible.map(d => d.label + `\n(${d.n_signs})`), axisLabel: { fontSize: 11, lineHeight: 14 } },
      yAxis: { type: "value", axisLabel: { formatter: v => (v >= 0 ? "+" : "") + v.toFixed(1) + " pp" }, splitLine: { lineStyle: { color: "#eef0f4" } } },
      series: [
        {
          name: "Raw 2025 change (post − pre)", type: "bar",
          data: visible.map(d => d.delta_2025 == null ? null : Number(d.delta_2025.toFixed(2))),
          itemStyle: { color: "#94a3b8", borderRadius: [2,2,0,0] },
          label: { show: true, position: "top", fontSize: 10, formatter: p => fmt.pp(p.value) },
        },
        {
          name: "DiD-adjusted (subtracts 2024 control)", type: "bar",
          data: visible.map(d => d.did == null ? null : Number(d.did.toFixed(2))),
          itemStyle: { color: "#c0392b", borderRadius: [2,2,0,0] },
          label: { show: true, position: "top", fontSize: 10, color: "#c0392b", formatter: p => fmt.pp(p.value) },
        },
      ],
    });
    window.addEventListener("resize", () => chart.resize());
  }

  // ---------- back-to-office (RTO) volume DiD ----------
  function renderRTO() {
    if (!S.rto || !S.rto.areas) return;
    document.getElementById("rtoCard").style.display = "";
    const order = ["downtown", "midtown", "outer"];
    const tilesEl = document.getElementById("rtoTiles");
    const sign = v => v == null ? "—" : (v >= 0 ? "+" : "") + v.toFixed(1) + " pp";
    const pctSign = v => v == null ? "—" : (v >= 0 ? "+" : "") + v.toFixed(1) + "%";
    tilesEl.innerHTML = order
      .filter(k => S.rto.areas[k])
      .map(k => {
        const a = S.rto.areas[k];
        const cls = a.did_pp > 0 ? "pos" : "neg";
        const tileCls = k === "downtown" ? "downtown" : "";
        return `<div class="rto-tile ${tileCls}">
          <div class="lbl">${a.label}</div>
          <div class="nm">${a.wards_desc} · ${a.n_wards} ward${a.n_wards>1?"s":""}</div>
          <div class="did ${cls}">${sign(a.did_pp)}</div>
          <div class="breakdown">RTO-yr change ${pctSign(a.rto_pct)} · prior-yr baseline ${pctSign(a.baseline_pct)}</div>
        </div>`;
      }).join("");
  }

  // ---------- per-ASE-camera ranking ----------
  function renderCameraRank() {
    if (!S.ase_camera_ranked || !S.ase_camera_ranked.length) return;
    document.getElementById("cameraRankCard").style.display = "";
    // Sort ascending so the largest DiD lands at the TOP of the horizontal-bar y-axis
    const data = S.ase_camera_ranked.slice()
      .filter(c => c.did != null)
      .sort((a, b) => a.did - b.did);
    const chart = echarts.init(document.getElementById("cameraRankChart"), null, { renderer: "canvas" });
    chart.setOption({
      grid: { left: 320, right: 100, top: 16, bottom: 30 },
      tooltip: { trigger: "axis", axisPointer: { type: "shadow" },
        formatter: p => {
          const it = data[p[0].dataIndex];
          return `<b>${it.location}</b><br>${it.n_signs} WYS signs within 500 m` +
                 (it.status ? `<br>ASE status: ${it.status}` : "") +
                 `<br>2025 pre: ${fmt.pct(it.pre_2025)} → post: ${fmt.pct(it.post_2025)}` +
                 `<br>Raw Δ: ${fmt.pp(it.delta_2025)}<br><b>DiD-adjusted: ${fmt.pp(it.did)}</b>`;
        },
      },
      xAxis: { type: "value", name: "DiD-adjusted change (pp)", nameLocation: "middle", nameGap: 22,
               axisLabel: { formatter: v => (v >= 0 ? "+" : "") + v.toFixed(1) } },
      yAxis: { type: "category",
               data: data.map(c => c.location.length > 48 ? c.location.slice(0, 46) + "…" : c.location),
               axisLabel: { fontSize: 11 } },
      series: [{
        type: "bar",
        data: data.map(c => ({ value: Number(c.did.toFixed(2)),
                               itemStyle: { color: c.did > 0 ? "#c0392b" : "#2e7d4f", borderRadius: [0, 2, 2, 0] } })),
        label: { show: true, position: "right", fontSize: 11, color: "#0f172a",
                 formatter: p => fmt.pp(p.value) + ` · n=${data[p.dataIndex].n_signs}` },
      }],
    });
    window.addEventListener("resize", () => chart.resize());
  }

  // ---------- year-over-year tier comparison ----------
  function renderYoY() {
    if (!S.yoy_city) return;
    const y = S.yoy_city;
    const tiers = S.yoy_tiers || [10, 15, 20, 25, 30];
    const win = `${y.current_window[0]}–${y.current_window[y.current_window.length-1]} vs ${y.prior_window[0]}–${y.prior_window[y.prior_window.length-1]}`;
    document.getElementById("yoyWindow").textContent = `Jan–Apr 2026 vs Jan–Apr 2025 · ${y.n_signs.toLocaleString()} signs reporting in both windows`;
    const t10 = y.tiers["10"] || y.tiers[10];
    document.getElementById("yoyBlurb").innerHTML =
      `Across all signs reporting in both windows, <b>${t10.this.toLocaleString()}</b> vehicles were measured at 10+ km/h over the limit this year, vs <b>${t10.last.toLocaleString()}</b> in the same window last year — an extra <b class="${t10.delta > 0 ? 'pos' : 'neg'}">${t10.delta >= 0 ? "+" : ""}${t10.delta.toLocaleString()}</b> speeders (<b class="${t10.pct_change > 0 ? 'pos' : 'neg'}">${t10.pct_change >= 0 ? "+" : ""}${t10.pct_change.toFixed(1)}%</b>).`;

    // Tiles
    const tilesEl = document.getElementById("yoyTiles");
    tilesEl.innerHTML = tiers.map(t => {
      const r = y.tiers[String(t)] || y.tiers[t];
      const cls = r.pct_change == null ? "neutral" : (r.pct_change > 0 ? "pos" : "neg");
      const arrow = r.pct_change == null ? "" : (r.pct_change > 0 ? "▲" : "▼");
      return `<div class="yoy-tile">
        <div class="tier">${t}+ km/h over limit</div>
        <div class="this">${r.this.toLocaleString()}</div>
        <div class="last">last yr: ${r.last.toLocaleString()}</div>
        <div class="pct ${cls}">${arrow} ${r.pct_change >= 0 ? "+" : ""}${r.pct_change.toFixed(1)}% &nbsp; (${r.delta >= 0 ? "+" : ""}${r.delta.toLocaleString()})</div>
      </div>`;
    }).join("");

    // Grouped bar chart
    const chart = echarts.init(document.getElementById("yoyTierChart"), null, { renderer: "canvas" });
    const lastVals = tiers.map(t => (y.tiers[String(t)] || y.tiers[t]).last);
    const thisVals = tiers.map(t => (y.tiers[String(t)] || y.tiers[t]).this);
    chart.setOption({
      grid: { left: 70, right: 24, top: 36, bottom: 30 },
      legend: { top: 0, textStyle: { fontSize: 12 } },
      tooltip: { trigger: "axis", valueFormatter: v => v == null ? "—" : Number(v).toLocaleString() + " vehicles" },
      xAxis: { type: "category", data: tiers.map(t => `${t}+ km/h over`), axisLabel: { fontSize: 12 } },
      yAxis: { type: "value", axisLabel: { formatter: v => v >= 1e6 ? (v/1e6).toFixed(1) + "M" : v >= 1000 ? (v/1000).toFixed(0) + "k" : v } },
      series: [
        { name: "Last year (Jan–Apr 2025)", type: "bar", data: lastVals, itemStyle: { color: "#94a3b8", borderRadius: [2,2,0,0] } },
        {
          name: "This year (Jan–Apr 2026)", type: "bar", data: thisVals, itemStyle: { color: "#c0392b", borderRadius: [2,2,0,0] },
          label: {
            show: true, position: "top", fontSize: 11, color: "#0f172a",
            formatter: p => {
              const r = y.tiers[String(tiers[p.dataIndex])] || y.tiers[tiers[p.dataIndex]];
              return (r.pct_change >= 0 ? "+" : "") + r.pct_change.toFixed(1) + "%";
            },
          },
        },
      ],
    });
    window.addEventListener("resize", () => chart.resize());
  }

  function renderYoYTop(tier) {
    if (!S.yoy_top) return;
    tier = tier || 20;
    const data = (S.yoy_top[String(tier)] || S.yoy_top[tier] || []).slice().reverse();
    let chart = window._yoyTopChart;
    if (!chart) {
      chart = echarts.init(document.getElementById("yoyTopChart"), null, { renderer: "canvas" });
      window._yoyTopChart = chart;
      window.addEventListener("resize", () => chart.resize());
      chart.on("click", p => {
        const it = (S.yoy_top[String(window._yoyTopActiveTier)] || S.yoy_top[window._yoyTopActiveTier] || []).slice().reverse()[p.dataIndex];
        if (it) openSign(it.sign_id);
      });
    }
    window._yoyTopActiveTier = tier;
    chart.setOption({
      grid: { left: 260, right: 120, top: 16, bottom: 30 },
      tooltip: {
        trigger: "axis", axisPointer: { type: "shadow" },
        formatter: p => {
          const it = data[p[0].dataIndex];
          return `<b>${it.name}</b><br>Ward ${it.ward} · limit ${it.limit} km/h<br>Last year (Jan–Apr 2025): <b>${it.last.toLocaleString()}</b><br>This year (Jan–Apr 2026): <b>${it.this.toLocaleString()}</b><br>Δ: <b>${it.delta >= 0 ? "+" : ""}${it.delta.toLocaleString()}</b> (<b>${it.pct >= 0 ? "+" : ""}${it.pct.toFixed(1)}%</b>)<br>Vehicles this yr: ${it.this_vol.toLocaleString()}<br><i>Click to open</i>`;
        },
      },
      xAxis: { type: "value", name: "Extra " + tier + "+ km/h-over speeders vs last year", nameLocation: "middle", nameGap: 22, axisLabel: { formatter: v => v >= 1000 ? (v/1000).toFixed(0) + "k" : v } },
      yAxis: { type: "category", data: data.map(x => x.name.length > 36 ? x.name.slice(0, 34) + "…" : x.name), axisLabel: { fontSize: 12 } },
      series: [{
        type: "bar",
        data: data.map(x => ({ value: x.delta, itemStyle: { color: "#c0392b", borderRadius: [0,2,2,0] } })),
        label: {
          show: true, position: "right", fontSize: 11, color: "#0f172a",
          formatter: p => {
            const it = data[p.dataIndex];
            return `+${it.delta.toLocaleString()}  (${it.pct >= 0 ? "+" : ""}${it.pct.toFixed(0)}%)`;
          },
        },
      }],
    });
  }

  document.addEventListener("click", e => {
    const b = e.target.closest("#yoyTierFilter button");
    if (!b) return;
    document.querySelectorAll("#yoyTierFilter button").forEach(x => x.classList.toggle("active", x === b));
    renderYoYTop(parseInt(b.dataset.tier, 10));
  });

  // ---------- city charts (speeding + ADT) ----------
  function timeChart(elId, data, color, fmtTip, type) {
    type = type || "line";
    const chart = echarts.init(document.getElementById(elId), null, { renderer: "canvas" });
    const isBar = type === "bar";
    const seriesBase = {
      type, data,
      markLine: {
        symbol: "none", silent: true,
        lineStyle: { color: "#0f172a", type: "dashed", width: 1 },
        label: { formatter: "ASE ban", position: "insideStartTop", color: "#0f172a", fontSize: 11 },
        data: [{ xAxis: "2025-11-01" }],
      },
      markArea: {
        silent: true,
        itemStyle: { color: "rgba(15,23,42,.05)" },
        data: [
          [{ xAxis: "2025-07-01" }, { xAxis: "2025-10-31" }],
          [{ xAxis: "2025-12-01" }, { xAxis: "2026-03-31" }],
        ],
      },
    };
    const series = isBar
      ? { ...seriesBase, itemStyle: { color, borderRadius: [2, 2, 0, 0] }, barCategoryGap: "15%" }
      : { ...seriesBase, smooth: true, symbol: "none",
          lineStyle: { width: 2, color },
          areaStyle: { color: color.replace("rgb", "rgba").replace(")", ",0.08)") } };
    chart.setOption({
      grid: { left: 60, right: 24, top: 24, bottom: 56 },
      tooltip: { trigger: "axis", valueFormatter: fmtTip },
      xAxis: { type: "time", boundaryGap: isBar },
      yAxis: { type: "value", scale: true, splitLine: { lineStyle: { color: "#eef0f4" } } },
      series: [series],
      dataZoom: [
        { type: "inside", start: 50, end: 100 },
        { type: "slider", height: 20, bottom: 16, start: 50, end: 100 },
      ],
    });
    window.addEventListener("resize", () => chart.resize());
    return chart;
  }

  function renderCityChart() {
    timeChart("cityChart", S.city_series, "rgb(192,57,43)",
              v => v == null ? "—" : v.toFixed(2) + "%");
    timeChart("cityAdtChart", S.city_adt_series, "rgb(26,86,219)",
              v => v == null ? "—" : Number(v).toLocaleString() + " vehicles/day", "bar");

    // ADT KPIs
    const a = S.adt_headline;
    document.getElementById("adtKpi").innerHTML = `
      <span>Pre-ban (Jul–Oct 2025): <b>${fmt.int(a.pre_2025)}</b></span>
      <span>Post-ban (Dec 2025–Mar 2026): <b>${fmt.int(a.post_2025)}</b></span>
      <span>Change: <b class="${a.delta_pct_2025 == null ? 'neutral' : (a.delta_pct_2025 > 0 ? 'pos' : 'neg')}">${fmt.intPct(a.delta_pct_2025)}</b></span>
      <span>2024 same-window change (control): <b>${fmt.intPct(a.delta_pct_2024)}</b></span>`;
  }

  // ---------- speed distribution overlay ----------
  function renderDistribution() {
    const d = S.distribution;
    const chart = echarts.init(document.getElementById("distChart"), null, { renderer: "canvas" });
    chart.setOption({
      grid: { left: 50, right: 20, top: 40, bottom: 50 },
      legend: { top: 0, textStyle: { fontSize: 12 } },
      tooltip: {
        trigger: "axis",
        valueFormatter: v => v == null ? "—" : Number(v).toFixed(2) + "%",
      },
      xAxis: {
        type: "category",
        data: d.labels,
        name: "Measured speed (km/h)",
        nameLocation: "middle", nameGap: 28,
        axisLabel: { interval: 1, fontSize: 10 },
      },
      yAxis: {
        type: "value",
        name: "% of all measurements",
        nameLocation: "middle", nameGap: 38,
        axisLabel: { formatter: "{value}%" },
      },
      series: [
        { name: "2024 pre  (Jul–Oct)",  type: "line", smooth: true, symbol: "none", lineStyle: { color: "#94a3b8", width: 1.5, type: "dotted" }, data: d.pre_2024_pct },
        { name: "2024 post (Dec–Mar)", type: "line", smooth: true, symbol: "none", lineStyle: { color: "#475569", width: 1.5, type: "dotted" }, data: d.post_2024_pct },
        { name: "2025 pre  (Jul–Oct)",  type: "line", smooth: true, symbol: "none", lineStyle: { color: "#1a56db", width: 2 }, areaStyle: { color: "rgba(26,86,219,.06)" }, data: d.pre_2025_pct },
        { name: "2025 post (Dec–Mar)", type: "line", smooth: true, symbol: "none", lineStyle: { color: "#c0392b", width: 2.5 }, areaStyle: { color: "rgba(192,57,43,.12)" }, data: d.post_2025_pct },
      ],
    });
    window.addEventListener("resize", () => chart.resize());
  }

  // ---------- top movers ----------
  function renderMovers() {
    const m = S.top_movers.slice().reverse(); // ECharts horizontal bar wants ascending for top-to-bottom
    const chart = echarts.init(document.getElementById("moversChart"), null, { renderer: "canvas" });
    chart.setOption({
      grid: { left: 280, right: 60, top: 16, bottom: 24 },
      tooltip: {
        trigger: "axis", axisPointer: { type: "shadow" },
        formatter: p => {
          const it = m[p[0].dataIndex];
          return `<b>${it.name}</b><br>Ward ${it.ward} ${it.ward_name}<br>Limit ${it.limit} km/h<br>Pre: ${fmt.pct(it.pre_2025)} → Post: ${fmt.pct(it.post_2025)}<br>DiD-adj: <b>${fmt.pp(it.did)}</b>`;
        },
      },
      xAxis: { type: "value", axisLabel: { formatter: v => (v >= 0 ? "+" : "") + v.toFixed(0) + " pp" } },
      yAxis: {
        type: "category",
        data: m.map(x => x.name.length > 38 ? x.name.slice(0, 36) + "…" : x.name),
        axisLabel: { fontSize: 12 },
      },
      series: [{
        type: "bar",
        data: m.map(x => ({
          value: x.did,
          itemStyle: { color: x.did > 0 ? "#c0392b" : "#2e7d4f" },
        })),
        label: { show: true, position: "right", formatter: p => fmt.pp(p.value), fontSize: 11 },
      }],
    });
    chart.on("click", p => {
      const it = m[p.dataIndex];
      if (it) openSign(it.sign_id);
    });
    window.addEventListener("resize", () => chart.resize());
  }

  // ---------- map ----------
  function renderMap() {
    const map = L.map("map", { preferCanvas: true }).setView([43.7, -79.4], 11);
    L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
      maxZoom: 19,
      attribution: "© OpenStreetMap",
    }).addTo(map);

    const wysCluster = L.markerClusterGroup({ maxClusterRadius: 50, disableClusteringAtZoom: 14 });
    S.signs.forEach(s => {
      const m = L.circleMarker([s.lat, s.lon], {
        radius: 6, weight: 1, color: "#1f2937",
        fillColor: colorFor(s.latest), fillOpacity: 0.9,
      });
      const did = s.did == null ? "" : ` · DiD ${fmt.pp(s.did)}`;
      m.bindPopup(`<b>${s.name || "Sign " + s.sign_id}</b><br>${s.address || ""}<br>Limit ${s.limit} · Latest ${fmt.pct(s.latest)}${did}<br><a href="#" data-open-sign="${s.sign_id}">Open detail ▸</a>`);
      m.on("popupopen", e => {
        const link = e.popup._contentNode.querySelector("[data-open-sign]");
        if (link) link.addEventListener("click", ev => { ev.preventDefault(); openSign(s.sign_id); });
      });
      wysCluster.addLayer(m);
    });
    map.addLayer(wysCluster);

    const aseLayer = L.layerGroup();
    S.ase.forEach(a => {
      const icon = L.divIcon({
        className: "ase-icon",
        html: `<div style="width:18px;height:18px;border-radius:3px;background:#0f172a;color:#fff;text-align:center;font:bold 11px/18px sans-serif;border:1px solid #fff;box-shadow:0 0 0 1px #0f172a">A</div>`,
        iconSize: [18, 18], iconAnchor: [9, 9],
      });
      const m = L.marker([a.lat, a.lon], { icon, title: a.location });
      m.bindPopup(`<b>ASE camera</b><br>${a.location}<br><i>Status:</i> ${a.status}<br>${a.ward_label || ""}`);
      aseLayer.addLayer(m);
    });

    L.control.layers(null, {
      "Watch Your Speed signs": wysCluster,
      "ASE camera locations": aseLayer,
    }, { collapsed: false }).addTo(map);

    // Legend
    const legend = L.control({ position: "bottomleft" });
    legend.onAdd = () => {
      const div = L.DomUtil.create("div", "");
      div.style.cssText = "background:#fff;padding:8px 10px;border:1px solid #e3e6ec;border-radius:6px;font:12px/1.3 sans-serif";
      div.innerHTML = `<b>Latest % &gt;10 over</b><br>
        <span style="display:inline-block;width:12px;height:12px;background:${colorFor(2)};border-radius:50%;border:1px solid #1f2937;vertical-align:middle"></span> ≤2%
        <span style="display:inline-block;width:12px;height:12px;background:${colorFor(10)};border-radius:50%;border:1px solid #1f2937;margin-left:8px;vertical-align:middle"></span> ~10%
        <span style="display:inline-block;width:12px;height:12px;background:${colorFor(18)};border-radius:50%;border:1px solid #1f2937;margin-left:8px;vertical-align:middle"></span> ≥18%`;
      return div;
    };
    legend.addTo(map);

    setTimeout(() => map.invalidateSize(), 100);
  }

  // ---------- ward grid + panel ----------
  let wardChart = null;
  let wardAdtChart = null;
  let activeWard = null;

  function renderWardGrid() {
    const grid = document.getElementById("wardGrid");
    grid.innerHTML = "";
    // Rank by DiD-adjusted change (descending; nulls last)
    const ranked = S.ward_summary.slice().sort((a, b) => {
      const av = a.did == null ? -Infinity : a.did;
      const bv = b.did == null ? -Infinity : b.did;
      return bv - av;
    });
    ranked.forEach((w, i) => {
      const card = document.createElement("div");
      card.className = "ward-card";
      card.dataset.ward = w.ward;
      const did = w.did;
      const cls = did == null ? "neutral" : (did > 0 ? "pos" : "neg");
      const arrow = did == null ? "" : (did > 0 ? "▲" : "▼");
      const rankCls = did == null ? "muted" : (did > 0 ? "" : "muted");
      card.innerHTML = `
        <div class="num"><span class="rank ${rankCls}">#${i + 1}</span> Ward ${w.ward} · ${w.n_signs} signs</div>
        <div class="nm">${w.name}</div>
        <div class="stat">Latest <span class="v">${fmt.pct(w.latest)}</span></div>
        <div class="stat">DiD-adj <span class="v ${cls}">${arrow} ${fmt.pp(did)}</span></div>
        <div class="spark" data-spark="${w.ward}"></div>`;
      card.addEventListener("click", () => openWard(w.ward));
      grid.appendChild(card);
    });
    // sparklines
    ranked.forEach(w => {
      const el = grid.querySelector(`[data-spark="${w.ward}"]`);
      if (!el || !w.series24) return;
      const chart = echarts.init(el, null, { renderer: "canvas" });
      chart.setOption({
        grid: { left: 0, right: 0, top: 2, bottom: 2 },
        xAxis: { type: "time", show: false, boundaryGap: false },
        yAxis: { type: "value", show: false, scale: true },
        series: [{ type: "line", smooth: true, symbol: "none", data: w.series24, lineStyle: { width: 1.5, color: "#c0392b" }, areaStyle: { color: "rgba(192,57,43,.12)" } }],
      });
    });
  }

  async function ensureFull() {
    if (FULL) return FULL;
    const r = await fetch("./data.json");
    FULL = await r.json();
    return FULL;
  }

  async function openWard(ward, opts) {
    activeWard = ward;
    if (!(opts && opts.skipHash)) {
      try { history.replaceState(null, "", "#ward=" + ward); } catch (e) {}
    }
    document.querySelectorAll(".ward-card").forEach(c => c.classList.toggle("active", String(c.dataset.ward) === String(ward)));
    const panel = document.getElementById("wardPanel");
    panel.classList.add("open");
    const w = S.ward_summary.find(x => x.ward === ward);
    document.getElementById("wardPanelTitle").textContent = `Ward ${ward} — ${w.name}`;
    const wardSigns = S.signs.filter(s => s.ward === ward);
    const nearAseCount = wardSigns.filter(s => s.nearest_ase_m != null && s.nearest_ase_m <= 500).length;
    const aseSuffix = nearAseCount > 0 ? ` · 📷 ${nearAseCount} within 500 m of a former ASE camera` : "";
    document.getElementById("wardPanelMeta").textContent = `${w.n_signs} signs · DiD-adjusted ${fmt.pp(w.did)}${aseSuffix}`;
    panel.scrollIntoView({ behavior: "smooth", block: "start" });

    const data = await ensureFull();
    const series = data.ward_monthly[ward] || [];
    const adtSeries = data.ward_adt[ward] || [];
    if (!wardChart) wardChart = echarts.init(document.getElementById("wardChart"), null, { renderer: "canvas" });
    wardChart.setOption({
      grid: { left: 60, right: 24, top: 24, bottom: 50 },
      tooltip: { trigger: "axis", valueFormatter: v => v == null ? "—" : v.toFixed(2) + "%" },
      xAxis: { type: "time", boundaryGap: false },
      yAxis: { type: "value", scale: true, axisLabel: { formatter: "{value}%" } },
      series: [{
        type: "line", smooth: true, symbol: "none", data: series,
        lineStyle: { width: 2, color: "#c0392b" },
        areaStyle: { color: "rgba(192,57,43,.08)" },
        markLine: { symbol: "none", silent: true, lineStyle: { color: "#0f172a", type: "dashed" }, data: [{ xAxis: "2025-11-01" }] },
        markArea: { silent: true, itemStyle: { color: "rgba(15,23,42,.05)" }, data: [
          [{ xAxis: "2025-07-01" }, { xAxis: "2025-10-31" }],
          [{ xAxis: "2025-12-01" }, { xAxis: "2026-03-31" }],
        ]},
      }],
      dataZoom: [{ type: "inside" }, { type: "slider", height: 18, bottom: 14 }],
    });

    if (!wardAdtChart) wardAdtChart = echarts.init(document.getElementById("wardAdtChart"), null, { renderer: "canvas" });
    wardAdtChart.setOption({
      grid: { left: 60, right: 24, top: 16, bottom: 30 },
      tooltip: { trigger: "axis", valueFormatter: v => v == null ? "—" : Number(v).toLocaleString() + " vehicles/day" },
      xAxis: { type: "time", boundaryGap: true },
      yAxis: { type: "value", scale: true, axisLabel: { formatter: v => v >= 1000 ? (v/1000).toFixed(0) + "k" : v } },
      series: [{
        type: "bar", data: adtSeries,
        itemStyle: { color: "#1a56db", borderRadius: [2, 2, 0, 0] },
        barCategoryGap: "15%",
        markLine: { symbol: "none", silent: true, lineStyle: { color: "#0f172a", type: "dashed" }, data: [{ xAxis: "2025-11-01" }] },
      }],
    });

    renderWardTable(ward);
  }

  function renderWardTable(ward, sortKey="latest", asc=false) {
    const tbody = document.querySelector("#wardTable tbody");
    const signs = S.signs.filter(s => s.ward === ward);
    signs.sort((a, b) => {
      let va = a[sortKey], vb = b[sortKey];
      if (va == null) va = -Infinity; if (vb == null) vb = -Infinity;
      if (typeof va === "string") return asc ? va.localeCompare(vb) : vb.localeCompare(va);
      return asc ? va - vb : vb - va;
    });
    tbody.innerHTML = signs.map(s => {
      const nearAse = s.nearest_ase_m != null && s.nearest_ase_m <= 500;
      const aseIcon = nearAse
        ? `<span class="ase-flag" title="Within ${Math.round(s.nearest_ase_m)} m of a former ASE camera location">📷</span> `
        : "";
      return `
      <tr class="signrow" data-sign="${s.sign_id}">
        <td>${aseIcon}${s.name || s.address || ("Sign " + s.sign_id)}</td>
        <td class="num">${s.limit}</td>
        <td class="num">${fmt.pct(s.latest)}</td>
        <td class="num ${s.delta_2025 == null ? "neutral" : (s.delta_2025 > 0 ? "pos" : "neg")}">${fmt.pp(s.delta_2025)}</td>
        <td class="num ${s.did == null ? "neutral" : (s.did > 0 ? "pos" : "neg")}">${fmt.pp(s.did)}</td>
      </tr>`;
    }).join("");
    tbody.querySelectorAll("tr").forEach(tr => tr.addEventListener("click", () => openSign(tr.dataset.sign)));
    document.querySelectorAll("#wardTable th").forEach(th => {
      th.classList.remove("sorted", "asc");
      if (th.dataset.sort === sortKey) {
        th.classList.add("sorted");
        if (asc) th.classList.add("asc");
      }
    });
  }

  document.addEventListener("click", e => {
    const th = e.target.closest("#wardTable th[data-sort]");
    if (th && activeWard != null) {
      const cur = th.classList.contains("sorted");
      const asc = cur && !th.classList.contains("asc");
      renderWardTable(activeWard, th.dataset.sort, asc);
    }
  });

  // ---------- sign panel ----------
  let signChart = null;
  let signAdtChart = null;
  let signBinsChart = null;
  let signHourChart = null;
  let signDowChart = null;
  async function openSign(sid, opts) {
    const sign = S.signs.find(s => String(s.sign_id) === String(sid));
    if (!sign) return;
    if (!(opts && opts.skipHash)) {
      try { history.replaceState(null, "", "#sign=" + encodeURIComponent(sid)); } catch (e) {}
    }
    const panel = document.getElementById("signPanel");
    panel.classList.add("open");
    document.getElementById("signPanelTitle").textContent = sign.name || sign.address || ("Sign " + sid);
    const aseLine = sign.nearest_ase_m == null
      ? ""
      : (sign.nearest_ase_m > 5000
          ? " · Nearest ASE: >5 km"
          : ` · Nearest ASE: ${Math.round(sign.nearest_ase_m).toLocaleString()} m`);
    document.getElementById("signPanelMeta").textContent =
      `Ward ${sign.ward} · ${sign.address || ""} · Limit ${sign.limit} km/h${aseLine}`;
    panel.scrollIntoView({ behavior: "smooth", block: "start" });

    const data = await ensureFull();
    const months = data.signs_monthly[sid] || {};
    const pairs = Object.entries(months).sort();
    if (!signChart) signChart = echarts.init(document.getElementById("signChart"), null, { renderer: "canvas" });
    signChart.setOption({
      grid: { left: 60, right: 24, top: 24, bottom: 50 },
      tooltip: { trigger: "axis", valueFormatter: v => v == null ? "—" : v.toFixed(2) + "%" },
      xAxis: { type: "time", boundaryGap: false },
      yAxis: { type: "value", scale: true, axisLabel: { formatter: "{value}%" } },
      series: [{
        type: "line", smooth: true, symbol: "circle", symbolSize: 4,
        data: pairs.map(([m, v]) => [m + "-01", v]),
        lineStyle: { width: 2, color: "#c0392b" },
        markLine: { symbol: "none", silent: true, lineStyle: { color: "#0f172a", type: "dashed" }, data: [{ xAxis: "2025-11-01" }] },
        markArea: { silent: true, itemStyle: { color: "rgba(15,23,42,.05)" }, data: [
          [{ xAxis: "2025-07-01" }, { xAxis: "2025-10-31" }],
          [{ xAxis: "2025-12-01" }, { xAxis: "2026-03-31" }],
        ]},
      }],
      dataZoom: [{ type: "inside" }, { type: "slider", height: 18, bottom: 14 }],
    });

    // ADT for this sign
    const adt = data.signs_adt[sid] || {};
    const adtPairs = Object.entries(adt).sort();
    if (!signAdtChart) signAdtChart = echarts.init(document.getElementById("signAdtChart"), null, { renderer: "canvas" });
    signAdtChart.setOption({
      grid: { left: 60, right: 24, top: 12, bottom: 26 },
      tooltip: { trigger: "axis", valueFormatter: v => v == null ? "—" : Number(v).toLocaleString() + " vehicles/day" },
      xAxis: { type: "time", boundaryGap: true },
      yAxis: { type: "value", scale: true, axisLabel: { formatter: v => v >= 1000 ? (v/1000).toFixed(0) + "k" : v } },
      series: [{
        type: "bar",
        data: adtPairs.map(([m, v]) => [m + "-01", Math.round(v)]),
        itemStyle: { color: "#1a56db", borderRadius: [2, 2, 0, 0] },
        barCategoryGap: "15%",
        markLine: { symbol: "none", silent: true, lineStyle: { color: "#0f172a", type: "dashed" }, data: [{ xAxis: "2025-11-01" }] },
      }],
    });

    // per-sign YoY tier table
    const yoy = data.yoy_signs && data.yoy_signs[sid];
    const tableEl = document.getElementById("signYoyTable");
    const winEl = document.getElementById("signYoyWindow");
    if (yoy) {
      const tiers = S.yoy_tiers || [10, 15, 20, 25, 30];
      winEl.textContent = `(${yoy.this_months} mo this yr / ${yoy.last_months} mo last yr · Jan–Apr 2026 vs 2025)`;
      let rows = `<table class="yoy-table" style="width:100%;font-size:13px">
        <thead><tr>
          <th>km/h over limit</th>
          <th class="num">Last year</th>
          <th class="num">This year</th>
          <th class="num">Δ count</th>
          <th class="num">Δ %</th>
        </tr></thead><tbody>`;
      tiers.forEach(t => {
        const last = yoy.last[String(t)] != null ? yoy.last[String(t)] : yoy.last[t];
        const ths  = yoy.this[String(t)] != null ? yoy.this[String(t)] : yoy.this[t];
        const delta = ths - last;
        const pct = last > 0 ? (delta / last * 100) : null;
        const cls = delta > 0 ? "pos" : (delta < 0 ? "neg" : "neutral");
        rows += `<tr>
          <td><b>${t}+</b> (e.g. ${sign.limit + t}+ km/h on a ${sign.limit} road)</td>
          <td class="num">${last.toLocaleString()}</td>
          <td class="num">${ths.toLocaleString()}</td>
          <td class="num ${cls}">${delta >= 0 ? "+" : ""}${delta.toLocaleString()}</td>
          <td class="num ${cls}">${pct == null ? "—" : (pct >= 0 ? "+" : "") + pct.toFixed(1) + "%"}</td>
        </tr>`;
      });
      rows += `<tr style="font-size:12px;color:var(--ink-soft)"><td>Total measured volume</td><td class="num">${yoy.last_vol.toLocaleString()}</td><td class="num">${yoy.this_vol.toLocaleString()}</td><td class="num">${(yoy.this_vol - yoy.last_vol).toLocaleString()}</td><td class="num">${yoy.last_vol ? (((yoy.this_vol - yoy.last_vol) / yoy.last_vol) * 100).toFixed(1) + "%" : "—"}</td></tr>`;
      rows += `</tbody></table>`;
      tableEl.innerHTML = rows;
      tableEl.style.display = "";
      winEl.style.display = "";
    } else {
      tableEl.style.display = "none";
      winEl.style.display = "none";
    }

    // hour-of-day + day-of-week (2023 baseline)
    const hourly = data.hourly && data.hourly.signs && data.hourly.signs[sid];
    const cityHourly = data.hourly && data.hourly.city;
    if (hourly && cityHourly) {
      if (!signHourChart) signHourChart = echarts.init(document.getElementById("signHourChart"), null, { renderer: "canvas" });
      const hours = Array.from({length: 24}, (_, i) => String(i).padStart(2, "0") + ":00");
      signHourChart.setOption({
        grid: { left: 60, right: 24, top: 32, bottom: 36 },
        legend: { top: 0, textStyle: { fontSize: 12 } },
        tooltip: { trigger: "axis", valueFormatter: v => v == null ? "—" : Math.round(v).toLocaleString() + " veh" },
        xAxis: { type: "category", data: hours, axisLabel: { fontSize: 10, interval: 1 } },
        yAxis: { type: "value", axisLabel: { formatter: v => v >= 1000 ? (v/1000).toFixed(0) + "k" : v } },
        series: [
          { name: "Weekday",  type: "bar", data: hourly.wk_per_hour, itemStyle: { color: "#c0392b", borderRadius: [2,2,0,0] }, barGap: "10%" },
          { name: "Weekend",  type: "bar", data: hourly.we_per_hour, itemStyle: { color: "#f0a000", borderRadius: [2,2,0,0] } },
          { name: "City avg (weekday)", type: "line", smooth: true, symbol: "none", data: cityHourly.wk_per_hour_avg, lineStyle: { color: "#0f172a", width: 1.5, type: "dashed" } },
        ],
      });

      if (!signDowChart) signDowChart = echarts.init(document.getElementById("signDowChart"), null, { renderer: "canvas" });
      const dowLabels = ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"];
      signDowChart.setOption({
        grid: { left: 60, right: 24, top: 16, bottom: 30 },
        tooltip: { trigger: "axis", valueFormatter: v => v == null ? "—" : Math.round(v).toLocaleString() + " veh" },
        xAxis: { type: "category", data: dowLabels },
        yAxis: { type: "value", axisLabel: { formatter: v => v >= 1000 ? (v/1000).toFixed(0) + "k" : v } },
        series: [{
          type: "bar", data: hourly.dow_per_day.map((v, i) => ({
            value: v,
            itemStyle: { color: i >= 5 ? "#f0a000" : "#1a56db", borderRadius: [2,2,0,0] }
          })),
          barCategoryGap: "20%",
        }],
      });
      document.getElementById("signHourChart").style.display = "";
      document.getElementById("signDowChart").style.display = "";
    } else {
      document.getElementById("signHourChart").style.display = "none";
      document.getElementById("signDowChart").style.display = "none";
    }

    // bins for latest month
    const bins = data.signs_bins[sid];
    if (!signBinsChart) signBinsChart = echarts.init(document.getElementById("signBins"), null, { renderer: "canvas" });
    if (bins) {
      const cutoff = sign.limit;
      const hasPrior = bins.prior_values && bins.prior_values.length === bins.values.length;
      const series = [];
      // Prior-year bars (left of each pair, light gray — sits in the background)
      if (hasPrior) {
        series.push({
          name: `Last year (${bins.prior_month})`,
          type: "bar",
          data: bins.prior_values,
          itemStyle: { color: "rgba(148,163,184,0.45)", borderRadius: [2, 2, 0, 0] },
        });
      }
      // This year (right of each pair), colored by speed-over-limit.
      // Three-step palette at matched saturation so the green/orange/red
      // progression reads as a continuum, not three competing colors.
      //   ≤ limit       → green-600 (#16a34a)
      //   1–9 over      → orange-500 (#f97316)
      //   10+ over      → red-600 (#dc2626)
      const limitIdx = bins.lowers.indexOf(cutoff);
      series.push({
        name: `This year (${bins.month})`,
        type: "bar",
        data: bins.values.map((v, i) => ({
          value: v,
          itemStyle: { color: bins.lowers[i] >= cutoff + 10 ? "#dc2626" : (bins.lowers[i] > cutoff ? "#f97316" : "#16a34a"), borderRadius: [2, 2, 0, 0] },
        })),
        markLine: {
          symbol: "none", silent: true,
          data: limitIdx >= 0 ? [{ xAxis: limitIdx - 0.5 }] : [],
          lineStyle: { color: "#0f172a", type: "dashed" },
          label: { formatter: `Posted ${cutoff} km/h`, color: "#0f172a", fontSize: 11 },
        },
      });
      signBinsChart.setOption({
        grid: { left: 50, right: 16, top: 36, bottom: 40 },
        legend: { top: 0, textStyle: { fontSize: 12 } },
        tooltip: { trigger: "axis", valueFormatter: v => v == null ? "—" : Number(v).toLocaleString() + " veh" },
        xAxis: { type: "category", data: bins.labels, axisLabel: { rotate: 0, interval: 1, fontSize: 10 } },
        yAxis: { type: "value", axisLabel: { formatter: v => v >= 1000 ? (v/1000).toFixed(0) + "k" : v } },
        series,
      });
    }
  }

  // ---------- init ----------
  renderKPIs();
  renderYoY();
  renderYoYTop(20);
  renderSpatial();
  renderCameraRank();
  renderRTO();
  renderCityChart();
  renderDistribution();
  renderMap();
  renderMovers();
  renderWardGrid();

  // Deep-link handling: parse the URL hash so /#sign=123 or /#ward=3 opens
  // that panel on load (and shareable links work). Falls back to the Ward 3
  // default-open if no hash is present.
  function applyHash() {
    const h = window.location.hash.replace(/^#/, "");
    if (!h) return false;
    const params = new URLSearchParams(h.replace(/^\?/, ""));
    const sid = params.get("sign") || (h.startsWith("sign=") ? h.slice(5) : null);
    const w = params.get("ward") || (h.startsWith("ward=") ? h.slice(5) : null);
    if (sid) { openSign(sid); return true; }
    if (w) { openWard(parseInt(w, 10)); return true; }
    return false;
  }
  if (!applyHash()) {
    const mimico = S.ward_summary.find(w => w.ward === 3);
    if (mimico) setTimeout(() => openWard(3, { skipHash: true }), 250);
  }
  window.addEventListener("hashchange", () => applyHash());
})();
</script>

</body>
</html>
