<style>
  :root {
    --bg: #f7f8fa;
    --ink: #11151c;
    --ink-soft: #4a5263;
    --line: #e3e6ec;
    --card: #ffffff;
    --accent: #c0392b;
    --accent-soft: #fde6e3;
    --good: #2e7d4f;
    --bad: #c0392b;
    --neutral: #6b7280;
  }
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; background: var(--bg); color: var(--ink); font: 15px/1.5 -apple-system, BlinkMacSystemFont, "Segoe UI", Inter, Roboto, system-ui, sans-serif; }
  a { color: #1a56db; }
  h1, h2, h3 { margin: 0 0 .25em; font-weight: 600; letter-spacing: -0.01em; }
  h1 { font-size: 28px; }
  h2 { font-size: 20px; margin-top: 2em; }
  h3 { font-size: 16px; }

  header.hero { background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); color: #fff; padding: 28px 32px; }
  header.hero .wrap { max-width: 1400px; margin: 0 auto; }
  header.hero .tag { display: inline-block; padding: 3px 10px; background: rgba(192,57,43,.2); border: 1px solid rgba(192,57,43,.6); border-radius: 999px; font-size: 11px; text-transform: uppercase; letter-spacing: .1em; color: #ffb4ab; margin-bottom: 10px; }
  header.hero h1 { color: #fff; }
  header.hero p { color: #a3aec3; max-width: 70ch; margin: 8px 0 0; }
  .disclaimer-bar { background: #fef7e6; color: #6b4f00; border-bottom: 1px solid #f1d977; padding: 8px 32px; font-size: 12.5px; line-height: 1.5; }
  .disclaimer-bar a { color: #6b4f00; text-decoration: underline; }
  .disclaimer-bar b { color: #4d3a00; }

  .wrap { max-width: 1400px; margin: 0 auto; padding: 0 32px; }
  section { padding: 24px 0; }

  .kpis { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin-top: 18px; }
  .kpi { background: var(--card); border: 1px solid var(--line); border-radius: 10px; padding: 16px 18px; }
  .kpi .label { font-size: 12px; text-transform: uppercase; letter-spacing: .08em; color: var(--ink-soft); margin-bottom: 6px; }
  .kpi .value { font-size: 28px; font-weight: 600; letter-spacing: -0.02em; }
  .kpi .sub { font-size: 12px; color: var(--ink-soft); margin-top: 4px; }
  .kpi.headline { background: linear-gradient(180deg, #fff, #fff3f0); border-color: #f1cbc5; }
  .kpi.headline .value { color: var(--accent); }
  .pos { color: var(--bad); }
  .neg { color: var(--good); }
  .neutral { color: var(--neutral); }

  .card { background: var(--card); border: 1px solid var(--line); border-radius: 10px; padding: 20px; margin-bottom: 18px; }
  .card .head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }
  .small { font-size: 13px; color: var(--ink-soft); }

  #cityChart, #cityAdtChart { width: 100%; height: 320px; }
  #distChart { width: 100%; height: 340px; }
  #moversChart { width: 100%; height: 520px; }
  #wardChart { width: 100%; height: 320px; }
  #wardAdtChart { width: 100%; height: 200px; }
  #signChart { width: 100%; height: 280px; }
  #signAdtChart { width: 100%; height: 180px; }
  #signBins { width: 100%; height: 240px; }
  #signHourChart { width: 100%; height: 240px; }
  #signDowChart { width: 100%; height: 180px; }
  #yoyTierChart { width: 100%; height: 320px; }
  #yoyTopChart { width: 100%; height: 540px; }
  #spatialChart { width: 100%; height: 340px; }
  #cameraRankChart { width: 100%; height: 620px; }
  .rto-tiles { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
  .rto-tile { padding: 16px 18px; border: 1px solid var(--line); border-radius: 8px; background: #fff; }
  .rto-tile.downtown { border-color: #f1cbc5; background: linear-gradient(180deg, #fff, #fff3f0); }
  .rto-tile .lbl { font-size: 12px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--ink-soft); }
  .rto-tile .nm { font-size: 13px; color: var(--ink-soft); margin: 2px 0 8px; }
  .rto-tile .did { font-family: var(--serif), Georgia, serif; font-size: 32px; font-weight: 700; line-height: 1; letter-spacing: -0.02em; font-variant-numeric: tabular-nums; }
  .rto-tile .did.pos { color: var(--accent); }
  .rto-tile .did.neg { color: var(--good); }
  .rto-tile .breakdown { font-size: 13px; color: var(--ink-soft); margin-top: 8px; font-variant-numeric: tabular-nums; }
  @media (max-width: 900px) { .rto-tiles { grid-template-columns: 1fr; } }
  .ward-card .rank { display: inline-block; font-size: 10px; font-weight: 700; color: #fff; background: var(--accent); padding: 2px 6px; border-radius: 10px; margin-right: 4px; vertical-align: middle; }
  .ward-card .rank.muted { background: #94a3b8; }
  .yoy-tile-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; }
  .yoy-tile { background: var(--card); border: 1px solid var(--line); border-radius: 8px; padding: 14px; }
  .yoy-tile .tier { font-size: 11px; text-transform: uppercase; letter-spacing: .08em; color: var(--ink-soft); }
  .yoy-tile .this { font-size: 22px; font-weight: 600; font-variant-numeric: tabular-nums; margin-top: 4px; }
  .yoy-tile .last { font-size: 12px; color: var(--ink-soft); }
  .yoy-tile .pct { font-size: 13px; font-weight: 600; font-variant-numeric: tabular-nums; margin-top: 2px; }
  @media (max-width: 900px) { .yoy-tile-grid { grid-template-columns: repeat(2, 1fr); } }
  .tier-filter { display: inline-flex; gap: 4px; }
  .tier-filter button { background: #f3f5f9; border: 1px solid var(--line); border-radius: 6px; padding: 4px 10px; font: 12px/1 sans-serif; cursor: pointer; }
  .tier-filter button.active { background: var(--accent); color: #fff; border-color: var(--accent); }
  table.yoy-table td.num { text-align: right; }
  #map { width: 100%; height: 560px; border-radius: 8px; overflow: hidden; }
  .chart-row { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
  @media (max-width: 1000px) { .chart-row { grid-template-columns: 1fr; } }
  .mini-kpi { display: flex; gap: 18px; flex-wrap: wrap; margin: 8px 0 14px; font-size: 13px; color: var(--ink-soft); }
  .mini-kpi b { color: var(--ink); font-size: 16px; font-weight: 600; font-variant-numeric: tabular-nums; }

  .ward-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 10px; }
  .ward-card { background: var(--card); border: 1px solid var(--line); border-radius: 8px; padding: 12px 14px; cursor: pointer; transition: transform .08s, border-color .08s; }
  .ward-card:hover { border-color: #c8cdd6; transform: translateY(-1px); }
  .ward-card.active { border-color: var(--accent); background: var(--accent-soft); }
  .ward-card .num { font-size: 11px; color: var(--ink-soft); text-transform: uppercase; letter-spacing: .06em; }
  .ward-card .nm { font-weight: 600; font-size: 14px; margin: 2px 0 4px; }
  .ward-card .stat { font-size: 13px; }
  .ward-card .stat .v { font-weight: 600; font-variant-numeric: tabular-nums; }
  .spark { width: 100%; height: 28px; margin-top: 4px; }

  table { width: 100%; border-collapse: collapse; font-size: 13px; }
  th, td { text-align: left; padding: 6px 8px; border-bottom: 1px solid var(--line); }
  th { font-size: 11px; text-transform: uppercase; letter-spacing: .06em; color: var(--ink-soft); cursor: pointer; user-select: none; }
